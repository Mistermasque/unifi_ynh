#!/bin/bash

#=================================================
# IMPORT GENERIC HELPERS
#=================================================

source ../settings/scripts/_common.sh
source /usr/share/yunohost/helpers

ynh_print_info "Declaring files to be backed up..."

### In a backup script, settings are loaded from the existing install:
###   $domain, $path, $port, $guest_portal, $speed_test
###
### The backup destination is managed by YunoHost — ynh_backup declares
### what to copy; the framework handles the actual archiving.
###
### [resources.apt] (repos + packages) are NOT backed up — they are
### re-provisioned from the manifest during restore. Only application
### DATA must be declared here.

#=================================================
# BACKUP THE NGINX CONFIGURATION
#=================================================
# Backs up the reverse-proxy vhost created by ynh_config_add_nginx.
# Restored by ynh_config_add_nginx in the restore script (re-generated
# from the template, so this is mainly for auditing / diff purposes).
#=================================================

ynh_backup "/etc/nginx/conf.d/$domain.d/$app.conf"

#=================================================
# BACKUP UNIFI DATA
#=================================================
# /var/lib/unifi is the single directory that holds everything UniFi
# needs to restore a fully working controller:
#
#   data/        — MongoDB database files, system.properties, keystore
#   data/backup/ — UniFi's own auto-backup archives (.unf files)
#   cert/        — custom TLS certificates (if configured)
#
# This directory is owned by the unifi Debian package, not by YunoHost
# resources, so it must be declared explicitly here.
#=================================================

ynh_backup "/var/lib/unifi"

#=================================================
# BACKUP UNIFI LOGS
#=================================================
# Log files are not strictly required to restore a working controller
# but are useful for post-incident analysis.
# because log rotation keeps them bounded.
# Remove this section if you prefer leaner backups.
#=================================================

ynh_backup "/var/log/unifi"

#=================================================
# END OF SCRIPT
#=================================================

ynh_print_info "Backup script completed for $app. (YunoHost will then actually copy those files to the archive)."
