#!/bin/bash

#=================================================
# IMPORT GENERIC HELPERS
#=================================================

source _common.sh
source /usr/share/yunohost/helpers

### Variables automatically available from the manifest:
###   $domain        — chosen domain
###   $port          — 8443 (fixed, from [resources.ports])
###   $guest_portal  — "1" or "0"  (boolean install question)
###   $speed_test    — "1" or "0"  (boolean install question)
###
### The three APT repositories (MongoDB, Adoptium, UniFi) and their
### packages are fully provisioned by [resources.apt] in the manifest
### BEFORE this script runs. There is nothing left to do here for repo
### setup or package installation.

#=================================================
# DOWNLOAD, CHECK AND UNPACK SOURCE
#=================================================

# Load os infos
. /etc/os-release

ynh_script_progression "Add mongodb repository..."

curl -fsSL https://pgp.mongodb.com/server-8.0.asc | \
 gpg -o /etc/apt/keyrings/mongodb-server-8.0.gpg \
 --dearmor --yes

printf '%s\n' \
'Types: deb' \
'URIs: https://repo.mongodb.org/apt/debian' \
"Suites: $VERSION_CODENAME/mongodb-org/8.0" \
'Components: main' \
"Architectures: $(dpkg --print-architecture)" \
'Signed-By: /etc/apt/keyrings/mongodb-server-8.0.gpg' > /etc/apt/sources.list.d/mongodb-org-8.0.sources


ynh_script_progression "Add Adoptium repository..."

curl -fsSL https://packages.adoptium.net/artifactory/api/gpg/key/public | \
  sudo gpg --dearmor --yes -o /etc/apt/keyrings/adoptium.gpg

printf '%s\n' \
'Types: deb' \
'URIs: https://packages.adoptium.net/artifactory/deb' \
"Suites: $VERSION_CODENAME" \
'Components: main' \
"Architectures: $(dpkg --print-architecture)" \
'Signed-By: /etc/apt/keyrings/adoptium.gpg' > /etc/apt/sources.list.d/adoptium.sources


ynh_script_progression "Add Unifi repository..."

curl -fsSL https://dl.ui.com/unifi/unifi-repo.gpg | \
 sudo gpg -o /etc/apt/keyrings/unifi.gpg \
 --dearmor

printf '%s\n' \
'Types: deb' \
'URIs: https://www.ui.com/downloads/unifi/debian' \
"Suites: stable" \
'Components: ubiquiti' \
"Architectures: $(dpkg --print-architecture)" \
'Signed-By: /etc/apt/keyrings/unifi.gpg' > /etc/apt/sources.list.d/unifi.sources

ynh_script_progression "Install Unifi package..."

apt-get update
apt-get install unifi -y


#=================================================
# NGINX REVERSE PROXY CONFIGURATION
#=================================================
# UniFi's web interface runs on HTTPS/8443 with a self-signed cert.
# conf/nginx.conf proxies to https://localhost:__PORT__ with
# proxy_ssl_verify off (self-signed upstream cert).
#=================================================
ynh_script_progression "Configuring nginx reverse proxy..."

ynh_config_add_nginx

#=================================================
# OPEN FIREWALL PORTS
#=================================================
# Port 8443 is reverse-proxied by nginx — do NOT expose it directly.
#
# Always-required ports for device <-> controller communication:
#   UDP 3478   STUN — NAT traversal for APs / switches
#   TCP 8080   Inform channel — devices phone home to the controller
#   UDP 10001  Device discovery (L2/L3 broadcast)
#
# Conditionally-required ports driven by install questions:
#   TCP 8880   HTTP  guest-portal redirect  ($guest_portal)
#   TCP 8843   HTTPS guest-portal redirect  ($guest_portal)
#   TCP 6789   Mobile speed test            ($speed_test)
# If more port needed : https://help.ui.com/hc/en-us/articles/218506997-Required-Ports-Reference
#=================================================
ynh_script_progression "Opening required firewall ports..."

# Required ports (always opened)
ynh_hide_warnings yunohost firewall open 3478 "Unifi STUN (Session Traversal Utilities for NAT)" -p udp
ynh_hide_warnings yunohost firewall open 8080 "Unifi device management traffic" -p tcp
ynh_hide_warnings yunohost firewall open 10001 "Unifi device discovery" -p udp

# Optionnal ports

ynh_script_progression "Create guest portal firewall ports rules (8880, 8843)..."
ynh_hide_warnings yunohost firewall open 8880 "Unifi Hotspot portail redirection (HTTP)" -p tcp
ynh_hide_warnings yunohost firewall open 8843 "Unifi Hotspot portail redirection (HTTPS)" -p tcp
# Close thoses ports if not used (but will be still present in yunohost firewall config)
if [ "$guest_portal" -eq 0 ]; then
    ynh_hide_warnings yunohost firewall disallow TCP 8880
    ynh_hide_warnings yunohost firewall disallow TCP 8843
fi

ynh_script_progression "Create speed test firewall port rules (6789)..."
ynh_hide_warnings yunohost firewall open 6789 "Unifi mobile speed test" -p tcp
# Close thoses ports if not used (but will be still present in yunohost firewall config)
if [ "$speed_test" -eq 0 ]; then
    ynh_hide_warnings yunohost firewall disallow TCP 6789
fi

#=================================================
# INTEGRATE UNIFI SYSTEMD SERVICE IN YUNOHOST
#=================================================
# The unifi Debian package already installs and enables unifi.service.
# We do NOT call ynh_config_add_systemd — that helper is for apps that
# need a *new* service file. Here we simply register the existing one
# with YunoHost so it appears in the admin UI "Services" panel and its
# log is readable from the "Logs" tab.
#
# --needs_exposed_ports is intentionally NOT set for 8443 because that
# port is handled by nginx. YunoHost's diagnosis would otherwise flag a
# "port conflict" with the reverse proxy.
#=================================================
ynh_script_progression "Integrating UniFi service into YunoHost..."

yunohost service add unifi \
    --description="UniFi Network Controller" \
    --log="/var/log/unifi/server.log"

#=================================================
# WAIT FOR SERVICE TO BE READY
#=================================================
# The unifi package's post-install script already starts the service —
# we must NOT start or restart it ourselves or we risk interrupting the
# initial database migration that runs on first boot.
# Instead we simply wait until systemd reports the unit as "active",
# with a timeout so the install does not hang forever.
#
# Timeout rationale: UniFi starts a JVM + MongoDB; on a modest machine
# the first boot (schema migration included) can take 2-3 minutes.
# 300 s (5 min) is generous enough for slow hardware while still
# failing visibly if something is truly broken.
#=================================================
ynh_script_progression "Waiting for UniFi service to be ready..."

_unifi_wait_timeout=300   # seconds before giving up
_unifi_wait_interval=5    # seconds between each poll
_unifi_waited=0

while true; do
    # systemctl is-active returns 0 (exit code) once the unit has
    # reached the running state. Any other value (activating, failed,
    # inactive ...) means it is not ready yet.
    if systemctl is-active --quiet unifi; then
        ynh_print_info "UniFi service is active."
        break
    fi

    # Check for a hard failure so we don't burn the full timeout when
    # systemd already knows the unit has crashed.
    _unit_state=$(systemctl is-active unifi 2>/dev/null || true)
    if [ "$_unit_state" = "failed" ]; then
        ynh_die "UniFi service entered a failed state. Check the logs with: journalctl -u unifi --no-pager -n 50"
    fi

    if [ "$_unifi_waited" -ge "$_unifi_wait_timeout" ]; then
        ynh_die "UniFi service did not become active within ${_unifi_wait_timeout}s (current state: ${_unit_state}). Check the logs with: journalctl -u unifi --no-pager -n 50"
    fi

    ynh_print_info "UniFi not ready yet (state: ${_unit_state}) — waiting ${_unifi_wait_interval}s (${_unifi_waited}/${_unifi_wait_timeout}s elapsed)..."
    sleep "$_unifi_wait_interval"
    _unifi_waited=$(( _unifi_waited + _unifi_wait_interval ))
done

#=================================================
# END OF SCRIPT
#=================================================

ynh_script_progression "Installation of $app completed"
