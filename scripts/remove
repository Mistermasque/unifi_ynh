#!/bin/bash

#=================================================
# IMPORT GENERIC HELPERS
#=================================================

source _common.sh
source /usr/share/yunohost/helpers

### All settings saved at install time are automatically loaded as bash
### variables before this script runs:
###   $domain        — the domain the app was installed on
###   $port          — 8443
###   $guest_portal  — "1" or "0"
###   $speed_test    — "1" or "0"
###
### The [resources.apt] extras (MongoDB, Adoptium, UniFi repos + packages)
### are deprovisioned AUTOMATICALLY by YunoHost after this script exits.
### Do NOT call apt-get remove / purge for those packages here — the
### resource system handles it.
###
### $YNH_APP_PURGE is set to "1" when the admin chose "remove and purge
### data". Use it to decide whether to delete UniFi's data directory.

#=================================================
# STOP THE SERVICE
#=================================================
# Stop unifi before anything else so it releases file handles and ports.
# Ignore errors: if it is already stopped (crash, previous failed remove)
# we must not abort the rest of the cleanup.
#=================================================
ynh_script_progression "Stopping UniFi service..."

ynh_systemctl --service="unifi" --action="stop" || true

#=================================================
# REMOVE YUNOHOST SERVICE INTEGRATION
#=================================================
# Unregisters the service from the YunoHost admin UI and service tracker.
# Must be called BEFORE the package is removed (apt removes the unit file).
#=================================================
ynh_script_progression "Removing UniFi service from YunoHost..."

yunohost service remove unifi

#=================================================
# REMOVE NGINX CONFIGURATION
#=================================================
# Removes the reverse-proxy vhost and reloads nginx.
# This is the counterpart of ynh_config_add_nginx in the install script.
#=================================================
ynh_script_progression "Removing nginx configuration..."

ynh_config_remove_nginx

#=================================================
# CLOSE FIREWALL PORTS
#=================================================

ynh_unifi_close_ports

#=================================================
# PURGE DATA (only if the admin requested it)
#=================================================
# /var/lib/unifi  — network configuration, device database, backups
# /var/log/unifi  — log files
#
# These directories belong to the unifi Debian package, not to YunoHost
# resources, so they are NOT cleaned up automatically. We must handle
# them explicitly when the admin chooses "purge".
#
# WARNING: purging /var/lib/unifi is irreversible — all controller
# configuration, adopted device records and local backups are lost.
#=================================================
if [ "${YNH_APP_PURGE:-0}" -eq 1 ]; then
    ynh_script_progression "Purging UniFi data directories..."

    ynh_safe_rm "/var/lib/unifi"
    ynh_safe_rm "/var/run/unifi"
fi

#=================================================
# END OF SCRIPT
#=================================================

ynh_script_progression "Removal of $app completed"
