#!/bin/bash

#=================================================
# IMPORT GENERIC HELPERS
#=================================================

source ../settings/scripts/_common.sh
source /usr/share/yunohost/helpers

### During restore, YunoHost has already:
###   - Re-provisioned [resources.apt]: added the three APT repos,
###     downloaded and installed mongodb-org, temurin-17-jdk, unifi.
###     The unifi package post-install script will have started the
###     service — we stop it immediately below before touching data.
###   - Loaded all saved settings as bash variables:
###     $domain, $path, $port, $guest_portal, $speed_test

#=================================================
# STOP THE SERVICE BEFORE RESTORING DATA
#=================================================
# The apt resource installs the unifi package which auto-starts the
# service and begins its first-boot database initialisation.
# We MUST stop it before overwriting /var/lib/unifi with backup data,
# otherwise MongoDB will be writing to files we are about to replace,
# causing corruption.
#=================================================
ynh_script_progression "Stopping UniFi service before data restore..."

ynh_systemctl --service="unifi" --action="stop"

# Also stop mongod if it runs as a separate unit (some versions do)
systemctl stop mongod 2>/dev/null || true

#=================================================
# RESTORE NGINX CONFIGURATION
#=================================================
# Re-generates the reverse-proxy vhost from conf/nginx.conf using the
# restored $domain and $port settings, then reloads nginx.
# This is the restore counterpart of ynh_config_add_nginx in install.
#=================================================
ynh_script_progression "Restoring nginx configuration..."

ynh_config_add_nginx

#=================================================
# OPEN FIREWALL PORTS
#=================================================
# The firewall state is not saved in the backup — ports must be
# re-opened explicitly, mirroring the install script exactly.
#=================================================
ynh_script_progression "Re-opening firewall ports..."

# Core ports — always required
ynh_exec_warn_less yunohost firewall allow UDP 3478
ynh_exec_warn_less yunohost firewall allow TCP 8080
ynh_exec_warn_less yunohost firewall allow UDP 10001

# Optional — guest portal
if [ "${guest_portal:-0}" -eq 1 ]; then
    ynh_script_progression "Re-opening guest portal firewall ports (8880, 8843)..."
    ynh_exec_warn_less yunohost firewall allow TCP 8880
    ynh_exec_warn_less yunohost firewall allow TCP 8843
fi

# Optional — speed test
if [ "${speed_test:-0}" -eq 1 ]; then
    ynh_script_progression "Re-opening speed test firewall port (6789)..."
    ynh_exec_warn_less yunohost firewall allow TCP 6789
fi

#=================================================
# RESTORE UNIFI DATA DIRECTORY
#=================================================
# Overwrites /var/lib/unifi with the backed-up content.
# This restores the full controller state: network topology, adopted
# device records, WiFi/VLAN configuration, system.properties, keystore,
# and UniFi's own auto-backup archives.
#
# The unifi package creates /var/lib/unifi during installation, so the
# directory already exists. ynh_restore_file will overwrite it.
# chown/chmod are set to match what the package expects.
#=================================================
ynh_script_progression "Restoring UniFi data directory..."

ynh_restore_file --origin_path="/var/lib/unifi"

# Ensure ownership is correct after restore — the unifi package runs
# as the "unifi" system user created by the package's post-install.
chown -R unifi:unifi "/var/lib/unifi"

#=================================================
# RESTORE UNIFI LOGS
#=================================================
# Restore log files (non-critical — the service works without them).
# Skipped silently if they were not included in the backup.
#=================================================
ynh_script_progression "Restoring UniFi log files..."

if ynh_restore_file --origin_path="/var/log/unifi" --not_mandatory; then
    chown -R unifi:unifi "/var/log/unifi"
fi

#=================================================
# INTEGRATE UNIFI SERVICE IN YUNOHOST
#=================================================
# Re-register the unifi systemd unit with YunoHost's service tracker
# so it appears in the admin UI and its log is reachable from the
# "Services" panel. Mirrors the call in the install script exactly.
#=================================================
ynh_script_progression "Re-integrating UniFi service into YunoHost..."

yunohost service add unifi \
    --description="UniFi Network Controller" \
    --log="/var/log/unifi/server.log"

#=================================================
# START SERVICE AND WAIT FOR READINESS
#=================================================
# Start the service now that restored data is in place, then wait for
# it to become active using the same polling loop as the install script.
# The first start after a restore may be slower than usual because
# MongoDB may need to replay its journal before accepting connections.
#=================================================
ynh_script_progression "Starting UniFi service..."

ynh_systemctl --service="unifi" --action="start"

ynh_unifi_wait_until_active

#=================================================
# END OF SCRIPT
#=================================================

ynh_script_progression "Restore of $app completed"
